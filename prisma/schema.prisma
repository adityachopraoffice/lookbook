// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Lookbook {
  id          String          @id @default(cuid())
  shop        String          // Shopify shop domain, for multi-tenant scoping
  title       String
  status      String          @default("DRAFT") // 'DRAFT' or 'PUBLISHED'
  layout      String          @default("GRID")  // 'HERO', 'GRID', or 'SLIDESHOW'
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  images      LookbookImage[]
}

model LookbookImage {
  id          String     @id @default(cuid())
  lookbookId  String
  lookbook    Lookbook   @relation(fields: [lookbookId], references: [id], onDelete: Cascade)
  imageUrl    String     // Shopify Files API CDN URL
  position    Int        // sort order within the lookbook
  pins        Pin[]
}

model Pin {
  id            String        @id @default(cuid())
  imageId       String
  image         LookbookImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
  xPercent      Float         // 0-100
  yPercent      Float         // 0-100
  productId     String        // Shopify product GID
  variantId     String?       // Shopify variant GID, optional
}

model ShopSettings {
  id             String @id @default(cuid())
  shop           String @unique
  defaultLayout  String @default("GRID")
  hotspotColor   String @default("#000000")
}
